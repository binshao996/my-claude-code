  "executions": [
    {
      "toolName": "Read",
      "input": {
        "file_path": "hello.txt"
      },
      "setupFiles": {
        "hello.txt": "hello\nworld\n"
      },
      "expectedContentIncludes": [
        "1\thello",
        "2\tworld"
      ],
      "expectedIsError": false
    },
    {
      "toolName": "Glob",
      "input": {
        "pattern": "**/*.ts"
      },
      "setupFiles": {
        "src/a.ts": "export {}",
        "README.md": "# hi"
      },
      "expectedContentIncludes": [
        "src/a.ts"
      ],
      "expectedContentExcludes": [
        "README.md"
      ],
      "expectedIsError": false
    },
    {
      "toolName": "Grep",
      "input": {
        "pattern": "needle",
        "path": "."
      },
      "setupFiles": {
        "src/a.ts": "needle\n",
        "src/b.ts": "hay\n"
      },
      "expectedContentIncludes": [
        "src/a.ts"
      ],
      "expectedContentExcludes": [
        "src/b.ts:1"
      ],
      "expectedIsError": false
    },
    {
      "toolName": "Write",
      "input": {
        "file_path": "out.txt",
        "content": "written"
      },
      "permissionMode": "acceptEdits",
      "expectedContentIncludes": [
        "Wrote "
      ],
      "expectedFiles": [
        {
          "path": "out.txt",
          "includes": [
            "written"
          ]
        }
      ],
      "expectedIsError": false
    },
    {
      "toolName": "Write",
      "input": {
        "file_path": "out.txt",
        "content": "blocked"
      },
      "permissionMode": "default",
      "expectedContentIncludes": [
        "Write wants to modify out.txt"
      ],
      "expectedIsError": true,
      "expectedPermissionDecision": "deny",
      "expectedFiles": [
        {
          "path": "out.txt",
          "exists": false
        }
      ]
    },
    {
      "toolName": "Bash",
      "input": {
        "command": "pwd"
      },
      "expectedContentIncludes": [
        "<cwd>"
      ],
      "expectedIsError": false
    },
    {
      "toolName": "Bash",
      "input": {
        "command": "rm -rf ."
      },
      "expectedContentIncludes": [
        "requires confirmation"
      ],
      "expectedIsError": true,
      "expectedPermissionDecision": "deny"
    },
    {
      "toolName": "TodoWrite",
      "input": {
        "todos": [
          {
            "id": "todo-1",
            "content": "ship R1.4",
            "status": "pending",
            "priority": "high"
          }
        ]
      },
      "expectedContentIncludes": [
        "Updated 1 todo"
      ],
      "expectedIsError": false,
      "expectedFiles": [
        {
          "path": ".my-claude-code/todos/latest.json",
          "includes": [
            "ship R1.4"
          ]
        }
      ]
    },
    {
      "toolName": "TaskCreate",
      "input": {
        "title": "Mirror tools"
      },
      "expectedContentIncludes": [
        "Mirror tools",
        "pending"
      ],
      "expectedFiles": [
        {
          "path": ".my-claude-code/tasks/tasks.json",
          "includes": [
            "Mirror tools"
          ]
        }
      ],
      "expectedIsError": false
    },
    {
      "toolName": "TeamCreate",
      "input": {
        "team_name": "alpha",
        "description": "mirror team",
        "agent_type": "lead"
      },
      "expectedContentIncludes": [
        "alpha",
        "team_name"
      ],
      "expectedFiles": [
        {
          "path": ".my-claude-code/teams/current.json",
          "includes": [
            "alpha"
          ]
        },
        {
          "path": ".my-claude-code/teams/alpha/config.json",
          "includes": [
            "alpha"
          ]
        }
      ],
      "expectedIsError": false
    },
    {
      "toolName": "SendMessage",
      "input": {
        "to": "missing",
        "message": "hello",
        "summary": "hello missing teammate"
      },
      "expectedContentIncludes": [
        "Not in a team context"
      ],
      "expectedIsError": false
    },
    {
      "toolName": "RemoteTriggerTool",
      "input": {
        "sessionId": "remote-one",
        "name": "wake",
        "payload": {
          "reason": "golden"
        }
      },
      "expectedContentIncludes": [
        "remote-one",
        "wake"
      ],
      "expectedContentExcludes": [],
      "expectedFiles": [
        {
          "path": ".my-claude-code/remote/bridge.jsonl",
          "includes": [
            "remote.trigger",
            "wake"
          ]
        }
      ],
      "expectedIsError": false,
      "setupFiles": {
        ".my-claude-code/remote/sessions.json": "[{\"id\":\"remote-one\",\"name\":\"demo\",\"transport\":\"loopback\",\"root\":\".\",\"status\":\"connected\",\"tokenHash\":\"hash\",\"transcriptPath\":\"unused\",\"createdAt\":\"now\",\"updatedAt\":\"now\"}]\n"
      }
    },
    {
      "toolName": "ListPeersTool",
      "input": {},
      "expectedContentIncludes": [
        "[]"
      ],
      "expectedIsError": false
    },
    {
      "toolName": "SearchExtraTools",
      "input": {
        "query": "mcp"
      },
      "expectedContentIncludes": [
        "requires a concrete deferred runtime"
      ],
      "expectedIsError": true,
      "expectedPermissionDecision": "deny"
    },
    {
      "toolName": "MCPTool",
      "input": {
        "server": "demo",
        "tool": "ping"
      },
      "expectedContentIncludes": [
        "requires a concrete deferred runtime"
      ],
      "expectedIsError": true,
      "expectedPermissionDecision": "deny"
    }
  ]
}
