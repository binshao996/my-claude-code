#!/usr/bin/expect -f
match_max 10000000
log_user 1
set timeout -1
log_file -noappend "/Users/bin.ke/my-compony/my-claude-code/docs/refactor/tui-chain-comparison/18.6-compact/current.raw"
spawn -noecho /bin/bash "/Users/bin.ke/my-compony/my-claude-code/docs/refactor/tui-chain-comparison/18.6-compact/current.driver.sh"
set timeout 10
catch {expect { eof {} timeout {} }}
catch {send -- "Reply exactly: COMPACT_SEED"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {send -- "\r"}
set timeout 18
catch {expect { eof {} timeout {} }}
catch {send -- "/compact"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {send -- "\r"}
set timeout 26
catch {expect { eof {} timeout {} }}
catch {send -- "\004"}
set timeout 11
catch {expect { eof {} timeout {} }}
catch {send -- "\003"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {send -- "\003"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {close}
catch {wait}
exit 0
