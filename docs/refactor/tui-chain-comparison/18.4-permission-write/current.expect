#!/usr/bin/expect -f
match_max 10000000
log_user 1
set timeout -1
log_file -noappend "/Users/bin.ke/my-compony/my-claude-code/docs/refactor/tui-chain-comparison/18.4-permission-write/current.raw"
spawn -noecho /bin/bash "/Users/bin.ke/my-compony/my-claude-code/docs/refactor/tui-chain-comparison/18.4-permission-write/current.driver.sh"
set timeout 10
catch {expect { eof {} timeout {} }}
catch {send -- "Use the Write tool to create tui-permission-probe.txt containing hello."}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {send -- "\r"}
set timeout 20
catch {expect { eof {} timeout {} }}
catch {send -- "\003"}
set timeout 22
catch {expect { eof {} timeout {} }}
catch {send -- "\003"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {send -- "\003"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {close}
catch {wait}
exit 0
