#!/usr/bin/expect -f
match_max 10000000
log_user 1
set timeout -1
log_file -noappend "/Users/bin.ke/my-compony/my-claude-code/docs/refactor/tui-chain-comparison/18.3-tool-call-read/upstream.raw"
spawn -noecho /bin/bash "/Users/bin.ke/my-compony/my-claude-code/docs/refactor/tui-chain-comparison/18.3-tool-call-read/upstream.driver.sh"
set timeout 10
catch {expect { eof {} timeout {} }}
catch {send -- "Use the Read tool to read package.json and answer only the package name."}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {send -- "\r"}
set timeout 24
catch {expect { eof {} timeout {} }}
catch {send -- "\004"}
set timeout 26
catch {expect { eof {} timeout {} }}
catch {send -- "\003"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {send -- "\003"}
set timeout 1
catch {expect { eof {} timeout {} }}
catch {close}
catch {wait}
exit 0
